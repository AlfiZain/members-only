<section class="form-page">
  <div class="form-card">
    <div class="form-header">
      <h1><%= locals.title %></h1>
      <p>Insert the secret code</p>
    </div>

    <form action="/join-club" method="POST" class="form">

      <% if (locals.error) { %>
        <small class="field-error">
          <%= locals.error %>
        </small>
      <% } %>

      <div class="form-group">
        <label for="code"> Secret Code </label>

        <input type="password" id="code" name="code" required />

      </div>

      <button type="submit" class="form-submit">
        Verify
      </button>
    </form>
  </div>
</section>
